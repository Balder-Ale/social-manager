# -------------------
# Environment file for Social Manager (local dev)
# -------------------
# Database (Postgres) – le porte sono interne al network Docker, quindi qui usiamo il valore che il container expose
DATABASE_URL=postgresql://pi:pi@localhost:5432/pi?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Storage (MinIO – usato in locale)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=social-manager-assets

# OpenRouter – chiave API (registrati su https://openrouter.ai e prendi la chiave free tier)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pi runtime
PI_AGENT_PORT=4000

# Feature flags
MOCK_SOCIAL=true          # usa il mock dei social (no OAuth reale)
ENABLE_IMAGE_GEN=false    # sub‑agent image‑gen disattivato (puoi abilitare in seguito)

# Social Platform OAuth Credentials (per MOCK_SOCIAL=false)
# Ottieni queste credenziali registrando la tua app su:
# Instagram/Facebook: https://developers.facebook.com
# TikTok:            https://developers.tiktok.com
#INSTAGRAM_CLIENT_ID=
#INSTAGRAM_CLIENT_SECRET=
#INSTAGRAM_REDIRECT_URI=http://localhost:4001/api/auth/instagram/callback
#FACEBOOK_CLIENT_ID=
#FACEBOOK_CLIENT_SECRET=
#FACEBOOK_REDIRECT_URI=http://localhost:4001/api/auth/facebook/callback
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
#TIKTOK_REDIRECT_URI=http://localhost:4001/api/auth/tiktok/callback

# Front‑end – imposta la porta diversa per evitare conflitti con altri progetti
PORT=4001
