# .env.production – Per Fly.io deploy
# Copia in .env dopo aver lanciato `fly secrets set`
# I secret vengono impostati via:
#   fly secrets set DATABASE_URL=postgresql://...
#   fly secrets set OPENROUTER_API_KEY=sk-or-v1-...
#   fly secrets set MOCK_SOCIAL=false

PORT=4001
NODE_ENV=production
MOCK_SOCIAL=true
ENABLE_IMAGE_GEN=false
STORAGE_PROVIDER=minio